<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context="jp.xenia.emulator.EmulatorActivity">

    <jp.xenia.emulator.WindowSurfaceView
        android:id="@+id/emulator_surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <TextView
        android:id="@+id/emulator_fps_overlay"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="top|start"
        android:layout_marginStart="10dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/osd_badge"
        android:gravity="center"
        android:letterSpacing="0"
        android:minWidth="78dp"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:text="@string/emulator_fps_initial"
        android:textColor="@color/xenia_green_soft"
        android:textSize="12sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/emulator_osd_top_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/osd_panel"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/emulator_osd_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0"
                android:maxLines="1"
                android:text="@string/osd_default_title"
                android:textColor="@color/xenia_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/emulator_osd_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:letterSpacing="0"
                android:maxLines="1"
                android:text="@string/osd_app_title"
                android:textColor="@color/xenia_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/emulator_osd_runtime"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/osd_badge"
            android:gravity="center"
            android:letterSpacing="0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/osd_runtime_status"
            android:textColor="@color/xenia_green_soft"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/emulator_osd_warning"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/osd_warning"
        android:gravity="center"
        android:letterSpacing="0"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/osd_a64_research_active"
        android:textColor="@color/xenia_warning"
        android:textSize="13sp"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/emulator_in_game_menu"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000"
        android:clickable="true"
        android:focusable="true"
        android:focusableInTouchMode="true"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingStart="28dp"
        android:paddingTop="24dp"
        android:paddingEnd="28dp"
        android:paddingBottom="24dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="320dp"
            android:layout_height="match_parent"
            android:background="@drawable/osd_panel"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="20dp"
            android:paddingEnd="22dp"
            android:paddingBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0"
                android:text="@string/emulator_menu_title"
                android:textColor="@color/xenia_text"
                android:textSize="24sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:letterSpacing="0"
                android:text="@string/emulator_menu_subtitle"
                android:textColor="@color/xenia_text_secondary"
                android:textSize="13sp" />

            <Button
                android:id="@+id/emulator_menu_resume"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="26dp"
                android:text="@string/emulator_menu_resume"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/emulator_menu_controller_mapping"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="@string/emulator_menu_controller_mapping"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/emulator_menu_settings"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="@string/emulator_menu_settings"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/emulator_menu_exit_game"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:text="@string/emulator_menu_exit_game"
                android:textAllCaps="false" />

            <CheckBox
                android:id="@+id/emulator_menu_show_fps"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="14dp"
                android:text="@string/emulator_menu_show_fps"
                android:textColor="@color/xenia_text"
                android:textSize="15sp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:letterSpacing="0"
                android:text="@string/emulator_menu_controls_note"
                android:textColor="@color/xenia_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <ScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="18dp"
            android:layout_weight="1"
            android:background="@drawable/osd_panel"
            android:fillViewport="true"
            android:paddingStart="24dp"
            android:paddingTop="20dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0"
                    android:text="@string/emulator_menu_help_title"
                    android:textColor="@color/xenia_green_soft"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/emulator_menu_input_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:letterSpacing="0"
                    android:textColor="@color/xenia_text"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/emulator_menu_controller_help"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/xenia_text"
                    android:textSize="13sp" />
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</FrameLayout>
