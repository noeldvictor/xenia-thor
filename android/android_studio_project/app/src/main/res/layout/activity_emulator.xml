<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context="jp.xenia.emulator.EmulatorActivity">

    <jp.xenia.emulator.WindowSurfaceView
        android:id="@+id/emulator_surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/osd_panel"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/emulator_osd_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0"
                android:maxLines="1"
                android:text="@string/osd_default_title"
                android:textColor="@color/xenia_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/emulator_osd_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:ellipsize="end"
                android:letterSpacing="0"
                android:maxLines="1"
                android:text="@string/osd_app_title"
                android:textColor="@color/xenia_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/emulator_osd_runtime"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/osd_badge"
            android:gravity="center"
            android:letterSpacing="0"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:text="@string/osd_runtime_status"
            android:textColor="@color/xenia_green_soft"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/emulator_osd_warning"
        android:layout_width="wrap_content"
        android:layout_height="36dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@drawable/osd_warning"
        android:gravity="center"
        android:letterSpacing="0"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="@string/osd_jit_research_active"
        android:textColor="@color/xenia_warning"
        android:textSize="13sp" />
</FrameLayout>
